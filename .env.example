# Maskinporten client (test environment)
# The client ID from Samarbeidsportalen (the org's Maskinporten integration).
MASKINPORTEN_CLIENT_ID=

# Private key as a plain JWK JSON string. The "kid" must be included inside the JWK.
# Example: {"kty":"RSA","kid":"my-key-id","alg":"RS256","n":"...","e":"AQAB","d":"...", ...}
MASKINPORTEN_JWK=

# Altinn test-tools enterprise token generator credentials (used by /api/token)
ALTINN_USERNAME=
ALTINN_PASSWORD=
